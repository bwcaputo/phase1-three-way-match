# Copy to .env and fill in. Never commit .env.

# --- Odoo ---
ODOO_URL=http://localhost:8069
ODOO_DB=threeway
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Agent behavior ---
# Dollar threshold below which price variance is auto-tolerable
PRICE_VARIANCE_TOLERANCE_USD=5.00
# Percent variance (0.02 = 2%) tolerated before flag
PRICE_VARIANCE_TOLERANCE_PCT=0.02
# Quantity variance tolerated (units)
QUANTITY_VARIANCE_TOLERANCE=0
